    "error.missing.try.later" : {
      "comment" : "Error when Pokémon artwork cannot be loaded.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Žádný Pokémon se neobjevil! Účinek Repelentu stále trvá."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kein Pokémon erschienen! Die Wirkung des Schutzes hält noch an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No Pokémon appeared! The Repel’s effect is still active."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡No apareció ningún Pokémon! El efecto del Repelente sigue activo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucun Pokémon n’est apparu ! L’effet du Repousse est toujours actif."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nessun Pokémon è apparso! L’effetto del Repellente è ancora attivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポケモンは現れなかった！むしよけスプレーの効果がまだ続いている。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "포켓몬이 나타나지 않았다! 리펠 효과가 아직 지속 중이다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenhum Pokémon apareceu! O efeito do Repelente ainda está ativo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "没有宝可梦出现！喷雾的效果仍在持续。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "沒有寶可夢出現！噴霧的效果仍在持續。"
          }
        }
      }
    },
    "pokemon.notification.body.1" : {
      "comment" : "Notification body variant 1.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Co se skrývá v trávě — dokážete to uhodnout?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was versteckt sich im Gras — kannst du es erraten?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What’s hiding in the grass — can you guess it?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Qué se esconde en la hierba — puedes adivinarlo?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qu’est-ce qui se cache dans les hautes herbes — pouvez-vous deviner ?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cosa si nasconde nell’erba — riesci a indovinarlo?"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "草むらに隠れているのは何？当てられる？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "풀숲에 숨은 건 무엇일까요 — 맞출 수 있을까요?"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O que está escondido na grama — consegue adivinhar?"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "草丛里藏着什么——你能猜出来吗？"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "草叢裡藏著什麼——你能猜出來嗎？"
          }
        }
      }
    },
    "pokemon.notification.body.2" : {
      "comment" : "Notification body variant 2.",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podívejte se blíže a zjistěte, zda ho poznáte!"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schau genauer hin und sieh, ob du es erkennst!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take a closer look and see if you recognize it!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¡Mira más de cerca y comprueba si lo reconoces!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regardez de plus près et voyez si vous le reconnaissez !"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dai un’occhiata più da vicino e vedi se lo riconosci!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "よく見て、何かわかるかな？"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자세히 보고 무엇인지 맞춰보세요!"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dê uma olhada mais de perto e veja se reconhece!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仔细看看，看看你是否认得它！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仔細看看，看看你是否認得它！"
          }
        }
      }
    },
